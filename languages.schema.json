{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Extended Code Highlight languages",
  "oneOf": [
    {
      "$ref": "#/$defs/language"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/language"
          }
        }
      }
    }
  ],
  "$defs": {
    "language": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "tokens"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+$"
            }
          },
          "tokens": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "pattern"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9_-]+$"
                },
                "pattern": {
                  "type": "string"
                },
                "flags": {
                  "type": "string",
                  "pattern": "^[dgimsuvy]*$"
                },
                "lookbehind": {
                  "type": "boolean"
                },
                "greedy": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
  }
}
