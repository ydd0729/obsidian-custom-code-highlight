{
  "id": "generic",
  "tokens": [
    {
      "name": "comment",
      "pattern": "<!--[\\s\\S]*?-->|/\\*[\\s\\S]*?\\*/|//.*|#.*|;.*|--.*",
      "greedy": true
    },
    {
      "name": "string",
      "pattern": "\"\"\"[\\s\\S]*?\"\"\"|'''[\\s\\S]*?'''|`(?:\\\\.|[^`\\\\])*`|\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*'",
      "greedy": true
    },
    {
      "name": "keyword",
      "pattern": "\\b(?:abstract|and|as|async|await|break|case|catch|class|const|continue|def|default|defer|do|else|enum|export|extends|false|finally|fn|for|from|func|function|if|import|in|interface|let|match|module|namespace|new|null|or|package|private|protected|public|return|self|static|struct|switch|then|throw|trait|true|try|type|undefined|union|use|using|var|void|while|with|yield)\\b"
    },
    {
      "name": "builtin",
      "pattern": "\\b(?:Array|BigInt|Boolean|Date|Error|Float|Int|JSON|Map|Math|Number|Object|Promise|Set|String|Symbol|console|document|window)\\b"
    },
    {
      "name": "number",
      "pattern": "[-+]?\\b(?:0x[\\da-fA-F_]+|0b[01_]+|0o[0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][-+]?\\d[\\d_]*)?)\\b"
    },
    {
      "name": "function",
      "pattern": "\\b[A-Za-z_$][A-Za-z0-9_$-]*(?=\\s*\\()"
    },
    {
      "name": "property",
      "pattern": "\\b[A-Za-z_$][A-Za-z0-9_$-]*(?=\\s*:)|</?\\s*[A-Za-z][A-Za-z0-9:.-]*|\\.[A-Za-z_$][A-Za-z0-9_$-]*"
    },
    {
      "name": "variable",
      "pattern": "[$@%][A-Za-z_][A-Za-z0-9_.$-]*"
    },
    {
      "name": "operator",
      "pattern": "=>|->|===|!==|==|!=|<=|>=|&&|\\|\\||\\?\\.|[-+*/%=!<>.&|^~?:]+|[{}()[\\],.;]"
    }
  ]
}
