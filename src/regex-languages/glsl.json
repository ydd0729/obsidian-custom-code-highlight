    },
    {
      "name": "function",
      "pattern": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
    },
    {
      "name": "operator",
      "pattern": ">>=?|<<=?|\\+\\+|--|&&|\\|\\||==|!=|<=|>=|[-+*/%=!<>|&~^?:]+|[{}()[\\],.;]"
